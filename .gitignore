# macOS
.DS_Store
.AppleDouble
.LSOverride

# Python
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Obsidian — exclude plugins/themes (too large), keep only core config
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/graph.json
.obsidian/plugins/
.obsidian/themes/

# Audit logs — auto-generated by scripts/daily-audit.py (not knowledge)
# Ignore log files, but keep hand-written .md analysis docs (e.g. decay-triage)
logs/*
!logs/*.md

# Claudian plugin
.claudian/

# Claude local settings
.claude/settings.local.json

# PDFs — stored locally only (too large for GitHub)
papers/*.pdf
papers/**/*.pdf
.ingest-queue
.ingest-watcher.log

# Quartz build artifacts
quartz/node_modules/
quartz/public/
quartz/.quartz-cache/
# NOTE: quartz/content is NOT gitignored — Quartz uses globby with
# gitignore:true, which would cause it to skip all files in content/
# and emit 0 pages. The directory is recreated by the deploy workflow
# from wiki/ on each build.

